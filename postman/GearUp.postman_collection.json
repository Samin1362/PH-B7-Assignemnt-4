        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base}}/auth/login",
              "host": [
                "{{base}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gearup.com\",\n  \"password\": \"Admin@1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Seeded admin. Saves token to {{adminToken}}."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d && d.data && d.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', d.data.accessToken);",
                  "  console.log('saved adminToken');",
                  "}"
                ]
              }
            }
          ]
        },
